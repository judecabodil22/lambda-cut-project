# Lambda Cut Configuration - EXAMPLE
# Copy this file to .env and fill in your values

# YouTube Playlist URL
PLAYLIST_URL=https://www.youtube.com/playlist?list=YOUR_PLAYLIST_ID

# Google Gemini API Key (for AI script generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot Configuration (optional)
# If you don't want Telegram notifications, leave these blank
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# TTS Voice (default: Algenib)
TTS_VOICE=Algenib

# Playlist Index (default: 1, which video to download from playlist)
PLAYLIST_INDEX=1
